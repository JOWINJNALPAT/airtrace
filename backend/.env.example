# =============================================
# AirTrace Backend — Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# --- Database (PlanetScale / Railway / Aiven / etc.) ---
DB_HOST=your-database-host.example.com
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=airtrace
DB_PORT=3306

# --- Server ---
PORT=3000

# --- CORS ---
# Comma-separated list of allowed frontend origins, or * for all
# Example: https://your-site.netlify.app,https://yourdomain.com
ALLOWED_ORIGINS=*
